generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shared household ledger: both allowlisted Telegram users read/write the same
// data. `createdBy` records who added a row ("telegram:<id>").

model Category {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#10b981")
  kind      String   @default("expense") // "expense" | "income"
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  plannedItems PlannedItem[]

  @@map("categories")
}

// A named recurring monthly line under a category (e.g. "Rent", "Utilities").
// A category's monthly plan/budget is the sum of its planned items. `dayOfMonth`
// is the approximate charge (expense) / arrival (income) day. For income, before
// that day the current month's amount is still projected; on/after it the real
// income (already in the balance) is used. Expense day is informational.
model PlannedItem {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  amount     Int // planned monthly minor units (euro cents), positive
  dayOfMonth Int      @default(1) // 1..31
  active     Boolean  @default(true)
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@map("planned_items")
}

model Transaction {
  id         String   @id @default(cuid())
  kind       String // "expense" | "income"
  amount     Int // minor units (euro cents) — always positive
  categoryId String?
  note       String   @default("")
  createdBy  String   @default("") // "telegram:<id>"
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([categoryId])
  @@map("transactions")
}
