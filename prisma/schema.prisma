generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shared household ledger: both allowlisted Telegram users read/write the same
// data. `createdBy` records who added a row ("telegram:<id>").

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("circle") // lucide-react icon name
  color     String   @default("#10b981")
  kind      String   @default("expense") // "expense" | "income"
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  plan         CategoryPlan?

  @@map("categories")
}

// Monthly planned sum for a category (one per category). `amount` is the
// expected monthly total, matched against real spending by category over the
// calendar month. `dayOfMonth` only matters for income: before that day the
// current month's income is still projected; on/after it the real income (in
// the balance) is used instead. Expenses ignore the day.
model CategoryPlan {
  id         String   @id @default(cuid())
  categoryId String   @unique
  amount     Int // planned monthly minor units (euro cents), positive
  dayOfMonth Int      @default(1) // income arrival day (1..31)
  active     Boolean  @default(true)
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("category_plans")
}

model Transaction {
  id         String   @id @default(cuid())
  kind       String // "expense" | "income"
  amount     Int // minor units (euro cents) — always positive
  categoryId String?
  note       String   @default("")
  createdBy  String   @default("") // "telegram:<id>"
  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([categoryId])
  @@map("transactions")
}
