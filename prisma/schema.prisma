generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Shared household ledger: both allowlisted Telegram users read/write the same
// data. `createdBy` records who added a row ("telegram:<id>").

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String   @default("circle") // lucide-react icon name
  color     String   @default("#10b981")
  kind      String   @default("expense") // "expense" | "income"
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  plannedItems PlannedItem[]

  @@map("categories")
}

// Recurring monthly planned expense/income. `amount` is an ESTIMATE; the real
// transaction that fulfills it (linked via Transaction.plannedItemId) may differ.
// `dayOfMonth` is approximate — matching to a real charge allows a ±N day gap.
model PlannedItem {
  id         String   @id @default(cuid())
  name       String
  kind       String // "expense" | "income"
  amount     Int // estimated minor units (euro cents), positive
  dayOfMonth Int // 1..31, approximate charge day
  categoryId String?
  active     Boolean  @default(true)
  createdBy  String   @default("")
  createdAt  DateTime @default(now())

  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  transactions Transaction[]

  @@map("planned_items")
}

model Transaction {
  id            String   @id @default(cuid())
  kind          String // "expense" | "income"
  amount        Int // minor units (euro cents) — always positive
  categoryId    String?
  plannedItemId String? // set when this real tx fulfills a planned item
  note          String   @default("")
  createdBy     String   @default("") // "telegram:<id>"
  occurredAt    DateTime @default(now())
  createdAt     DateTime @default(now())

  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  plannedItem PlannedItem? @relation(fields: [plannedItemId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([categoryId])
  @@index([plannedItemId])
  @@map("transactions")
}
